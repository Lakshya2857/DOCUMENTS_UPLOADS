<!DOCTYPE html>
<html lang="en" id="html-tag" class="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
    </style>
</head>

<body class="bg-[#f8fafc] text-slate-900 dark:bg-slate-950 dark:text-slate-100 antialiased">

    <header
        class="bg-slate-900 text-white relative overflow-hidden border-b border-slate-800 dark:border-slate-900 shadow-2xl">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-600/10 to-purple-600/10 opacity-50"></div>
        <div
            class="max-w-7xl mx-auto px-6 py-6 relative z-10 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-gradient-to-tr from-blue-500 to-indigo-600 p-2.5 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 009 11V7a4 4 0 00-8 0v4c0 2.618.704 5.065 1.936 7.162M12 11a9 9 0 018.775 7.162M12 11v7M12 3a9 9 0 000 18v-3" />
                    </svg>
                </div>
                <div>
                    <h1
                        class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">
                        SECURE VAULT</h1>
                    <p class="text-xs text-blue-400 font-semibold tracking-wider uppercase">Employee & Document Hub</p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <button onclick="toggleTheme()" id="theme-btn"
                    class="p-2.5 rounded-xl bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 transition-all active:scale-95">
                    <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none"
                        viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.243 17.657l.707.707M6.343 6.364l.707.707M12 7a5 5 0 100 10 5 5 0 000-10z" />
                    </svg>
                    <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
                        viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                </button>
                <div class="flex items-center gap-3 bg-slate-800/60 border border-slate-700/60 px-4 py-2 rounded-xl">
                    <div
                        class="w-9 h-9 bg-gradient-to-br from-blue-400 to-indigo-600 text-white rounded-lg flex items-center justify-center font-bold text-sm">
                        SP</div>
                    <div class="text-left hidden sm:block">
                        <p class="text-xs font-bold text-slate-200">Surender Pal</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 py-10 grid grid-cols-1 lg:grid-cols-3 gap-8">

        <div class="lg:col-span-1">
            <div
                class="bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-200/80 dark:border-slate-800 sticky top-6">
                <div class="flex items-center gap-2 mb-6">
                    <span class="w-1.5 h-5 bg-blue-600 rounded-full"></span>
                    <h2 class="text-base font-bold text-slate-800 dark:text-slate-100">Add New Entry</h2>
                </div>

                <form id="add-entry-form" action="/add" method="POST" enctype="multipart/form-data" class="space-y-5">
                    <div>
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1.5">Full
                            Name</label>
                        <input type="text" name="name" placeholder="Enter name" required
                            class="w-full px-3.5 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:bg-slate-800 dark:text-white text-sm">
                    </div>
                    <div>
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1.5">Position</label>
                        <input type="text" name="position" placeholder="Designation" required
                            class="w-full px-3.5 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:bg-slate-800 dark:text-white text-sm">
                    </div>

                    <div class="border-t border-slate-100 dark:border-slate-800 pt-4">
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">Document
                            Containers / Boxes</label>

                        <div id="containers-list" class="space-y-4">
                            <!-- Dynamic containers will be added here -->
                        </div>

                        <button type="button" onclick="addNewContainer('containers-list')"
                            class="mt-3 w-full flex items-center justify-center gap-1.5 py-2.5 px-4 border border-dashed border-blue-500 dark:border-blue-600 text-blue-600 dark:text-blue-400 hover:bg-blue-50/50 dark:hover:bg-blue-950/20 rounded-xl text-xs font-bold transition-all duration-200">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-500" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 4v16m8-8H4" />
                            </svg>
                            Add Document Box
                        </button>
                    </div>

                    <button type="submit"
                        class="w-full bg-slate-900 dark:bg-blue-600 text-white font-bold py-3 px-4 rounded-xl shadow-lg text-sm">Save
                        to Cloud Vault</button>
                </form>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-6">
            <div
                class="bg-white dark:bg-slate-900 p-4 rounded-2xl shadow-sm border border-slate-200/80 dark:border-slate-800 flex items-center gap-3">
                <input type="text" id="search-input" oninput="filterRecords()"
                    placeholder="Search by personnel name or role..."
                    class="w-full bg-transparent text-sm text-slate-800 dark:text-slate-100 focus:outline-none">
            </div>

            <div
                class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200/80 dark:border-slate-800 overflow-hidden">
                <div
                    class="p-5 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/40">
                    <h2 class="text-base font-bold text-slate-800 dark:text-slate-100">System Records</h2>
                    <span id="active-counter"
                        class="bg-blue-50 dark:bg-slate-800 text-blue-700 dark:text-blue-400 text-xs font-bold px-2.5 py-1 rounded-md">Active
                        Logs: <%= (typeof employees !=='undefined' ) ? employees.length : 0 %></span>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr
                                class="bg-slate-50/70 dark:bg-slate-800/20 border-b border-slate-200 dark:border-slate-800 text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                                <th class="p-4">Personnel</th>
                                <th class="p-4">Role / Position</th>
                                <th class="p-4">Vault Attachments</th>
                                <th class="p-4 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="table-body" class="divide-y divide-slate-100 dark:divide-slate-800 text-sm">
                            <% if (typeof employees !=='undefined' && employees.length> 0) { %>
                                <% employees.forEach(function(emp, empIndex) { %>
                                    <tr
                                        class="record-row hover:bg-slate-50/80 dark:hover:bg-slate-800/40 transition-all">
                                        <td class="p-4 font-semibold text-slate-900 dark:text-slate-100 search-name">
                                            <%= emp.name %>
                                        </td>
                                        <td class="p-4">
                                            <span
                                                class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-semibold px-2 py-1 rounded-md search-position">
                                                <%= emp.position %>
                                            </span>
                                        </td>

                                        <td class="p-4 max-w-[240px]">
                                            <div class="space-y-2">
                                                <% const grouped={}; if (emp.documents && emp.documents.length> 0) {
                                                    emp.documents.forEach(function(doc) {
                                                    const cName = doc.container || 'General';
                                                    if (!grouped[cName]) grouped[cName] = [];
                                                    grouped[cName].push(doc);
                                                    });
                                                    }
                                                    const containerNames = Object.keys(grouped);
                                                    %>
                                                    <% if (containerNames.length> 0) { %>
                                                        <% containerNames.forEach(function(cName, cIdx) { %>
                                                            <div
                                                                class="border border-slate-200 dark:border-slate-800/80 rounded-xl overflow-hidden bg-slate-50/60 dark:bg-slate-900/40">
                                                                <button
                                                                    onclick="toggleContainerFiles('<%= empIndex %>', '<%= cIdx %>')"
                                                                    class="w-full flex items-center justify-between px-2.5 py-2 text-xs font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                                                                    <span class="truncate flex items-center gap-1.5">
                                                                        <span
                                                                            class="text-blue-500 dark:text-blue-400 text-sm">📁</span>
                                                                        <%= cName %>
                                                                    </span>
                                                                    <span
                                                                        class="text-[10px] bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2 py-0.5 rounded-full">
                                                                        <%= grouped[cName].length %>
                                                                    </span>
                                                                </button>
                                                                <div id="files-<%= empIndex %>-<%= cIdx %>"
                                                                    class="hidden border-t border-slate-200 dark:border-slate-800 divide-y divide-slate-100 dark:divide-slate-800 bg-white dark:bg-slate-950 p-2 space-y-1">
                                                                    <% grouped[cName].forEach(function(doc) { %>
                                                                        <div
                                                                            class="flex items-center justify-between p-1 rounded hover:bg-slate-50 dark:hover:bg-slate-900/60 text-[11px] gap-2">
                                                                            <span
                                                                                class="truncate text-slate-600 dark:text-slate-400 max-w-[130px]"
                                                                                title="<%= doc.title %>">
                                                                                <%= doc.title %>
                                                                            </span>
                                                                            <a href="<%= doc.url %>" target="_blank"
                                                                                class="text-[10px] text-blue-600 dark:text-blue-400 font-extrabold px-1.5 py-0.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded hover:bg-blue-50 dark:hover:bg-slate-850 transition-colors">
                                                                                View
                                                                            </a>
                                                                        </div>
                                                                        <% }) %>
                                                                </div>
                                                            </div>
                                                            <% }) %>
                                                                <% } else { %>
                                                                    <span
                                                                        class="text-xs text-slate-400 dark:text-slate-600 italic">No
                                                                        files uploaded</span>
                                                                    <% } %>
                                            </div>
                                        </td>

                                        <td class="p-4 text-center">
                                            <div class="flex items-center justify-center gap-2">
                                                <button
                                                    onclick="openEditModal('<%= emp._id %>', '<%= emp.name %>', '<%= emp.position %>', '<%= JSON.stringify(emp.documents) %>')"
                                                    class="text-xs text-amber-600 hover:text-white font-bold px-2.5 py-1.5 bg-white dark:bg-slate-900 hover:bg-amber-500 border border-amber-200 dark:border-amber-800 rounded-lg shadow-sm transition-all">
                                                    Edit
                                                </button>
                                                <form action="/delete/<%= emp._id %>" method="POST"
                                                    onsubmit="return confirm('Delete record?');">
                                                    <button type="submit"
                                                        class="text-xs text-rose-600 hover:text-white font-bold px-2.5 py-1.5 bg-white dark:bg-slate-900 hover:bg-rose-600 border border-rose-200 dark:border-rose-800 rounded-lg shadow-sm transition-all">Wipe</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                                            <tr id="search-empty-row" class="hidden">
                                                <td colspan="4" class="p-12 text-center text-slate-400">No records
                                                    found.</td>
                                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- Loading Overlay -->
    <div id="loading-overlay"
        class="fixed inset-0 bg-slate-950/60 backdrop-blur-md z-50 flex flex-col items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <div
            class="bg-white dark:bg-slate-900 rounded-2xl p-8 max-w-sm w-full mx-4 shadow-2xl border border-slate-200 dark:border-slate-800 text-center space-y-4">
            <div class="relative w-16 h-16 mx-auto">
                <div class="absolute inset-0 rounded-full border-4 border-slate-100 dark:border-slate-800"></div>
                <div class="absolute inset-0 rounded-full border-4 border-t-blue-500 animate-spin"></div>
            </div>
            <div>
                <h3 class="text-sm font-bold text-slate-800 dark:text-slate-100" id="loading-title">Uploading Documents
                </h3>
                <p class="text-xs text-slate-400 dark:text-slate-500 mt-1" id="loading-status">Encrypting & sending to
                    cloud vault...</p>
            </div>
        </div>
    </div>

    <div id="edit-modal"
        class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <div
            class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 w-full max-w-lg p-6 shadow-2xl m-4 transform scale-95 transition-transform duration-300">
            <div class="flex justify-between items-center border-b border-slate-100 dark:border-slate-800 pb-3 mb-4">
                <h3 class="text-base font-bold text-slate-800 dark:text-slate-100">Modify Vault Record</h3>
                <button type="button" onclick="closeEditModal()"
                    class="text-slate-400 hover:text-slate-600 font-bold">✕</button>
            </div>

            <form id="edit-form" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Full Name</label>
                    <input type="text" id="edit-name" name="name" required
                        class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 rounded-xl dark:bg-slate-800 text-sm">
                </div>
                <div>
                    <label
                        class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Designation</label>
                    <input type="text" id="edit-position" name="position" required
                        class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 rounded-xl dark:bg-slate-800 text-sm">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5">Currently
                        Stored Documents (Click ✕ to remove)</label>
                    <div id="existing-docs-list"
                        class="space-y-2 max-h-[140px] overflow-y-auto border border-slate-100 dark:border-slate-800 p-2 rounded-xl bg-slate-50/50 dark:bg-slate-800/30">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-2">Upload Additional
                        / New Files</label>

                    <div id="edit-containers-list" class="space-y-3">
                        <!-- Dynamic upload boxes will be added here -->
                    </div>

                    <button type="button" onclick="addNewContainer('edit-containers-list')"
                        class="mt-2 w-full flex items-center justify-center gap-1.5 py-2 px-4 border border-dashed border-amber-500 dark:border-amber-600 text-amber-600 dark:text-amber-400 hover:bg-amber-50/50 dark:hover:bg-amber-950/20 rounded-xl text-xs font-bold transition-all duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Add New File Box
                    </button>
                </div>

                <div class="flex justify-end gap-3 border-t border-slate-100 dark:border-slate-800 pt-4 mt-6">
                    <button type="button" onclick="closeEditModal()"
                        class="px-4 py-2 border border-slate-200 dark:border-slate-700 text-xs font-bold rounded-xl text-slate-600 dark:text-slate-400">Cancel</button>
                    <button type="submit"
                        class="px-5 py-2 bg-slate-900 dark:bg-blue-600 text-white text-xs font-bold rounded-xl shadow-md">Apply
                        Updates</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const htmlTag = document.getElementById('html-tag');
        const sunIcon = document.getElementById('sun-icon');
        const moonIcon = document.getElementById('moon-icon');

        if (localStorage.getItem('theme') === 'dark') {
            htmlTag.classList.add('dark'); sunIcon.classList.remove('hidden'); moonIcon.classList.add('hidden');
        }

        function toggleTheme() {
            if (htmlTag.classList.contains('dark')) {
                htmlTag.classList.remove('dark'); localStorage.setItem('theme', 'light');
                sunIcon.classList.add('hidden'); moonIcon.classList.remove('hidden');
            } else {
                htmlTag.classList.add('dark'); localStorage.setItem('theme', 'dark');
                sunIcon.classList.remove('hidden'); moonIcon.classList.add('hidden');
            }
        }

        // 📁 DYNAMIC VAULT CONTAINER SYSTEM
        function createContainerHTML(index, isEdit = false) {
            const prefix = isEdit ? 'edit-' : '';
            const defaultName = index === 0 ? (isEdit ? 'New Uploads' : 'General') : '';
            return `
                <div id="container-card-${prefix}${index}" class="bg-slate-50 dark:bg-slate-800/40 p-4 rounded-xl border border-slate-200 dark:border-slate-800/60 space-y-3 relative">
                    <div class="flex justify-between items-center gap-2">
                        <input type="text" name="containerNames" placeholder="Box Name (e.g. Images, IDs, Invoices)" value="${defaultName}" required
                               class="bg-transparent border-b border-slate-200 dark:border-slate-700 focus:border-blue-500 focus:outline-none text-xs font-bold text-slate-800 dark:text-slate-200 py-0.5 w-[75%] transition-colors">
                        ${index > 0 ? `
                        <button type="button" onclick="removeContainerCard(${index}, ${isEdit})" class="text-rose-500 hover:text-rose-700 font-extrabold text-xs">
                            Remove
                        </button>
                        ` : ''}
                    </div>
                    
                    <div class="bg-white dark:bg-slate-900 border border-dashed border-slate-300 dark:border-slate-700 rounded-lg p-3 text-center relative hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all cursor-pointer">
                        <input type="file" name="files_${index}" multiple required
                               onchange="handleContainerFilesChange(this, ${index}, ${isEdit})"
                               class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                        <div class="text-slate-400 dark:text-slate-500 space-y-1 pointer-events-none">
                            <span class="text-xs font-bold text-blue-500 dark:text-blue-400">Select Multiple Files</span>
                            <p class="text-[10px]">drag & drop or click</p>
                        </div>
                    </div>
                    <div id="container-files-list-${prefix}${index}" class="space-y-1 text-[11px] text-slate-500 dark:text-slate-400"></div>
                </div>
            `;
        }

        function addNewContainer(listId) {
            const isEdit = listId.includes('edit');
            const listElement = document.getElementById(listId);
            const containerIdx = listElement.children.length;

            const wrapper = document.createElement('div');
            wrapper.innerHTML = createContainerHTML(containerIdx, isEdit);
            listElement.appendChild(wrapper.firstElementChild);
        }

        function removeContainerCard(index, isEdit) {
            const prefix = isEdit ? 'edit-' : '';
            const card = document.getElementById(`container-card-${prefix}${index}`);
            if (card) {
                card.remove();
                reindexContainers(isEdit);
            }
        }

        function reindexContainers(isEdit) {
            const listId = isEdit ? 'edit-containers-list' : 'containers-list';
            const listElement = document.getElementById(listId);
            const cards = listElement.children;
            const prefix = isEdit ? 'edit-' : '';
            for (let i = 0; i < cards.length; i++) {
                const card = cards[i];
                card.id = `container-card-${prefix}${i}`;

                const fileInput = card.querySelector('input[type="file"]');
                if (fileInput) {
                    fileInput.name = `files_${i}`;
                    fileInput.setAttribute('onchange', `handleContainerFilesChange(this, ${i}, ${isEdit})`);
                }

                const filesList = card.querySelector('[id^="container-files-list-"]');
                if (filesList) {
                    filesList.id = `container-files-list-${prefix}${i}`;
                }

                const removeBtn = card.querySelector('button[onclick^="removeContainerCard"]');
                if (removeBtn) {
                    removeBtn.setAttribute('onclick', `removeContainerCard(${i}, ${isEdit})`);
                }
            }
        }

        function handleContainerFilesChange(inputElement, index, isEdit) {
            const prefix = isEdit ? 'edit-' : '';
            const filesList = document.getElementById(`container-files-list-${prefix}${index}`);
            filesList.innerHTML = '';

            const files = inputElement.files;
            if (files.length === 0) return;

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const item = document.createElement('div');
                item.className = 'flex justify-between items-center bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800 px-2 py-1 rounded shadow-sm font-medium';
                item.innerHTML = `
                    <span class="truncate max-w-[80%]">📄 ${file.name}</span>
                    <span class="text-slate-400 dark:text-slate-600 text-[10px]">(${(file.size / 1024).toFixed(1)} KB)</span>
                `;
                filesList.appendChild(item);
            }
        }

        function toggleContainerFiles(empIndex, cIdx) {
            const element = document.getElementById(`files-${empIndex}-${cIdx}`);
            if (element) {
                element.classList.toggle('hidden');
            }
        }

        // ☁️ CLIENT SIDE UPLOAD CONTROLLERS
        async function uploadFileToCloudinary(file) {
            const signRes = await fetch('/api/sign-upload', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ public_id: '' })
            });
            if (!signRes.ok) throw new Error('Failed to get signature');
            const signData = await signRes.json();

            const formData = new FormData();
            formData.append('file', file);
            formData.append('api_key', signData.api_key);
            formData.append('timestamp', signData.timestamp);
            formData.append('signature', signData.signature);
            formData.append('folder', signData.folder);

            const uploadRes = await fetch(`https://api.cloudinary.com/v1_1/${signData.cloud_name}/auto/upload`, {
                method: 'POST',
                body: formData
            });
            if (!uploadRes.ok) throw new Error('Cloudinary upload failed');
            const uploadData = await uploadRes.json();
            return uploadData.secure_url;
        }

        async function processFormUploads(formElement, containersListId) {
            const overlay = document.getElementById('loading-overlay');
            const statusEl = document.getElementById('loading-status');

            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);

            const listElement = document.getElementById(containersListId);
            if (!listElement) return true;

            const cards = listElement.children;
            const filesToUpload = [];

            for (let i = 0; i < cards.length; i++) {
                const card = cards[i];
                const containerNameInput = card.querySelector('input[name="containerNames"]');
                const containerName = containerNameInput ? containerNameInput.value.trim() : 'General';
                const fileInput = card.querySelector('input[type="file"]');

                if (fileInput && fileInput.files.length > 0) {
                    for (let j = 0; j < fileInput.files.length; j++) {
                        filesToUpload.push({
                            file: fileInput.files[j],
                            containerName: containerName
                        });
                    }
                }
            }

            const totalFiles = filesToUpload.length;
            for (let index = 0; index < totalFiles; index++) {
                const item = filesToUpload[index];
                statusEl.textContent = `Uploading ${item.file.name} (${index + 1}/${totalFiles})...`;
                try {
                    const secureUrl = await uploadFileToCloudinary(item.file);

                    const urlInput = document.createElement('input');
                    urlInput.type = 'hidden';
                    urlInput.name = 'docUrls';
                    urlInput.value = secureUrl;

                    const nameInput = document.createElement('input');
                    nameInput.type = 'hidden';
                    nameInput.name = 'docNames';
                    nameInput.value = item.file.name;

                    const containerInput = document.createElement('input');
                    containerInput.type = 'hidden';
                    containerInput.name = 'docContainers';
                    containerInput.value = item.containerName;

                    formElement.appendChild(urlInput);
                    formElement.appendChild(nameInput);
                    formElement.appendChild(containerInput);
                } catch (err) {
                    console.error(err);
                    alert(`Failed to upload ${item.file.name}. Please try again.`);
                    overlay.classList.add('opacity-0');
                    setTimeout(() => overlay.classList.add('hidden'), 300);
                    return false;
                }
            }

            // Disable binary inputs so browser doesn't send files to Vercel
            const fileInputs = formElement.querySelectorAll('input[type="file"]');
            fileInputs.forEach(input => input.disabled = true);

            statusEl.textContent = 'Finishing vault update...';
            return true;
        }

        function filterRecords() {
            const query = document.getElementById('search-input').value.toLowerCase().trim();
            const rows = document.querySelectorAll('.record-row');
            const emptyRow = document.getElementById('search-empty-row');
            const counter = document.getElementById('active-counter');
            let visibleCount = 0;

            rows.forEach(row => {
                const name = row.querySelector('.search-name').textContent.toLowerCase();
                const pos = row.querySelector('.search-position').textContent.toLowerCase();
                if (name.includes(query) || pos.includes(query)) {
                    row.classList.remove('hidden'); visibleCount++;
                } else { row.classList.add('hidden'); }
            });
            counter.textContent = `Active Logs: ${visibleCount}`;
            if (visibleCount === 0 && rows.length > 0) emptyRow.classList.remove('hidden'); else emptyRow.classList.add('hidden');
        }

        function openEditModal(id, name, position, documentsJson) {
            const modal = document.getElementById('edit-modal');
            const form = document.getElementById('edit-form');
            const existingContainer = document.getElementById('existing-docs-list');
            const editContainersList = document.getElementById('edit-containers-list');

            document.getElementById('edit-name').value = name;
            document.getElementById('edit-position').value = position;
            existingContainer.innerHTML = '';
            editContainersList.innerHTML = '';

            form.action = `/update/${id}`;
            const docs = JSON.parse(documentsJson);

            if (docs && docs.length > 0) {
                const groupedDocs = {};
                docs.forEach(doc => {
                    const cName = doc.container || 'General';
                    if (!groupedDocs[cName]) groupedDocs[cName] = [];
                    groupedDocs[cName].push(doc);
                });

                Object.keys(groupedDocs).forEach(cName => {
                    const containerDiv = document.createElement('div');
                    containerDiv.className = 'mb-3 border border-slate-200/60 dark:border-slate-800 rounded-xl p-2.5 bg-white dark:bg-slate-900';

                    const title = document.createElement('div');
                    title.className = 'text-xs font-bold text-slate-500 mb-1.5 flex items-center gap-1.5';
                    title.innerHTML = `<span>📁</span> ${cName}`;
                    containerDiv.appendChild(title);

                    const filesList = document.createElement('div');
                    filesList.className = 'space-y-1.5';

                    groupedDocs[cName].forEach(doc => {
                        const fileRow = document.createElement('div');
                        fileRow.className = 'flex items-center justify-between bg-slate-50 dark:bg-slate-800 px-3 py-1.5 rounded-lg text-xs border border-slate-200/50 dark:border-slate-700/50 shadow-sm';
                        fileRow.innerHTML = `
                            <span class="font-semibold text-slate-700 dark:text-slate-300 truncate mr-2" title="${doc.title}">${doc.title}</span>
                            <input type="hidden" name="retainedDocs" value="${doc._id}">
                            <button type="button" onclick="this.parentElement.remove()" class="text-rose-500 hover:text-rose-700 font-extrabold px-1">✕</button>
                        `;
                        filesList.appendChild(fileRow);
                    });

                    containerDiv.appendChild(filesList);
                    existingContainer.appendChild(containerDiv);
                });
            } else {
                existingContainer.innerHTML = `<p class="text-slate-400 text-xs text-center py-2">No documents currently assigned.</p>`;
            }

            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.querySelector('.transform').classList.remove('scale-95');
            }, 10);
        }

        function closeEditModal() {
            const modal = document.getElementById('edit-modal');
            modal.classList.add('opacity-0');
            modal.querySelector('.transform').classList.add('scale-95');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        // Initialize and bind events on load
        document.addEventListener('DOMContentLoaded', () => {
            addNewContainer('containers-list');

            const addForm = document.getElementById('add-entry-form');
            if (addForm) {
                let isSubmitting = false;
                addForm.addEventListener('submit', async (e) => {
                    if (isSubmitting) return;
                    e.preventDefault();
                    isSubmitting = true;

                    const success = await processFormUploads(addForm, 'containers-list');
                    if (success) {
                        addForm.submit();
                    } else {
                        isSubmitting = false;
                    }
                });
            }

            const editForm = document.getElementById('edit-form');
            if (editForm) {
                let isSubmitting = false;
                editForm.addEventListener('submit', async (e) => {
                    if (isSubmitting) return;
                    e.preventDefault();
                    isSubmitting = true;

                    const success = await processFormUploads(editForm, 'edit-containers-list');
                    if (success) {
                        editForm.submit();
                    } else {
                        isSubmitting = false;
                    }
                });
            }
        });
    </script>
</body>

</html>