<!DOCTYPE html>
<html lang="en" id="html-tag" class="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
    </style>
</head>

<body class="bg-[#f8fafc] text-slate-900 dark:bg-slate-950 dark:text-slate-100 antialiased">

    <header
        class="bg-slate-900 text-white relative overflow-hidden border-b border-slate-800 dark:border-slate-900 shadow-2xl">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-600/10 to-purple-600/10 opacity-50"></div>
        <div
            class="max-w-7xl mx-auto px-6 py-6 relative z-10 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-gradient-to-tr from-blue-500 to-indigo-600 p-2.5 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 009 11V7a4 4 0 00-8 0v4c0 2.618.704 5.065 1.936 7.162M12 11a9 9 0 018.775 7.162M12 11v7M12 3a9 9 0 000 18v-3" />
                    </svg>
                </div>
                <div>
                    <h1
                        class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">
                        SECURE VAULT</h1>
                    <p class="text-xs text-blue-400 font-semibold tracking-wider uppercase">Employee & Document Hub</p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <button onclick="toggleTheme()" id="theme-btn"
                    class="p-2.5 rounded-xl bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 transition-all active:scale-95">
                    <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none"
                        viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.243 17.657l.707.707M6.343 6.364l.707.707M12 7a5 5 0 100 10 5 5 0 000-10z" />
                    </svg>
                    <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
                        viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                </button>
                <div class="flex items-center gap-3 bg-slate-800/60 border border-slate-700/60 px-4 py-2 rounded-xl">
                    <div
                        class="w-9 h-9 bg-gradient-to-br from-blue-400 to-indigo-600 text-white rounded-lg flex items-center justify-center font-bold text-sm">
                        SP</div>
                    <div class="text-left hidden sm:block">
                        <p class="text-xs font-bold text-slate-200">Surender Pal</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 py-10 grid grid-cols-1 lg:grid-cols-3 gap-8">

        <div class="lg:col-span-1">
            <div
                class="bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-200/80 dark:border-slate-800 sticky top-6">
                <div class="flex items-center gap-2 mb-6">
                    <span class="w-1.5 h-5 bg-blue-600 rounded-full"></span>
                    <h2 class="text-base font-bold text-slate-800 dark:text-slate-100">Add New Entry</h2>
                </div>

                <form action="/add" method="POST" enctype="multipart/form-data" class="space-y-5">
                    <div>
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1.5">Full
                            Name</label>
                        <input type="text" name="name" placeholder="Enter name" required
                            class="w-full px-3.5 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:bg-slate-800 dark:text-white text-sm">
                    </div>
                    <div>
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1.5">Position</label>
                        <input type="text" name="position" placeholder="Designation" required
                            class="w-full px-3.5 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:bg-slate-800 dark:text-white text-sm">
                    </div>

                    <div class="border-t border-slate-100 dark:border-slate-800 pt-4">
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">Select
                            Documents (Multiple Allowed)</label>

                        <div
                            class="bg-slate-50 dark:bg-slate-800 p-5 rounded-xl border border-dashed border-slate-300 dark:border-slate-700 text-center hover:bg-slate-100/50 dark:hover:bg-slate-800/80 transition-all relative">
                            <input type="file" name="documents" id="master-file-input" multiple required
                                onchange="handleBulkFilesSelection(this, 'bulk-names-container')"
                                class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                            <div class="text-slate-400 dark:text-slate-500 space-y-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mx-auto text-blue-500"
                                    fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                                </svg>
                                <p class="text-xs font-bold text-blue-500 dark:text-blue-400">Click to Select Files</p>
                                <p class="text-[10px]">Hold Ctrl/Shift to pick multiple items</p>
                            </div>
                        </div>

                        <div id="bulk-names-container" class="space-y-2 mt-4 max-h-[220px] overflow-y-auto pr-1"></div>
                    </div>

                    <button type="submit"
                        class="w-full bg-slate-900 dark:bg-blue-600 text-white font-bold py-3 px-4 rounded-xl shadow-lg text-sm">Save
                        to Cloud Vault</button>
                </form>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-6">
            <div
                class="bg-white dark:bg-slate-900 p-4 rounded-2xl shadow-sm border border-slate-200/80 dark:border-slate-800 flex items-center gap-3">
                <input type="text" id="search-input" oninput="filterRecords()"
                    placeholder="Search by personnel name or role..."
                    class="w-full bg-transparent text-sm text-slate-800 dark:text-slate-100 focus:outline-none">
            </div>

            <div
                class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200/80 dark:border-slate-800 overflow-hidden">
                <div
                    class="p-5 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/40">
                    <h2 class="text-base font-bold text-slate-800 dark:text-slate-100">System Records</h2>
                    <span id="active-counter"
                        class="bg-blue-50 dark:bg-slate-800 text-blue-700 dark:text-blue-400 text-xs font-bold px-2.5 py-1 rounded-md">Active
                        Logs: <%= (typeof employees !=='undefined' ) ? employees.length : 0 %></span>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr
                                class="bg-slate-50/70 dark:bg-slate-800/20 border-b border-slate-200 dark:border-slate-800 text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                                <th class="p-4">Personnel</th>
                                <th class="p-4">Role / Position</th>
                                <th class="p-4">Vault Attachments</th>
                                <th class="p-4 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="table-body" class="divide-y divide-slate-100 dark:divide-slate-800 text-sm">
                            <% if (typeof employees !=='undefined' && employees.length> 0) { %>
                                <% employees.forEach(function(emp, empIndex) { %>
                                    <tr
                                        class="record-row hover:bg-slate-50/80 dark:hover:bg-slate-800/40 transition-all">
                                        <td class="p-4 font-semibold text-slate-900 dark:text-slate-100 search-name">
                                            <%= emp.name %>
                                        </td>
                                        <td class="p-4">
                                            <span
                                                class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-semibold px-2 py-1 rounded-md search-position">
                                                <%= emp.position %>
                                            </span>
                                        </td>

                                        <td class="p-4 max-w-[240px]">
                                            <div class="space-y-1.5">
                                                <% if (emp.documents && emp.documents.length> 0) { %>
                                                    <div
                                                        class="flex items-center justify-between bg-slate-100 dark:bg-slate-800 p-2 rounded-lg text-xs">
                                                        <span
                                                            class="truncate font-bold text-slate-700 dark:text-slate-300">
                                                            <%= emp.documents[0].title %>
                                                        </span>
                                                        <a href="<%= emp.documents[0].url %>" target="_blank"
                                                            class="text-[10px] text-blue-600 dark:text-blue-400 font-extrabold px-2 py-0.5 bg-white dark:bg-slate-900 rounded border border-slate-200 dark:border-slate-700">View</a>
                                                    </div>

                                                    <% if (emp.documents.length> 1) { %>
                                                        <div id="extra-docs-<%= empIndex %>"
                                                            class="hidden space-y-1.5 mt-1.5 transition-all">
                                                            <% emp.documents.slice(1).forEach(function(doc) { %>
                                                                <div
                                                                    class="flex items-center justify-between bg-slate-50 dark:bg-slate-800/60 p-2 rounded-lg text-xs border border-dashed border-slate-200 dark:border-slate-700">
                                                                    <span
                                                                        class="truncate text-slate-600 dark:text-slate-400">
                                                                        <%= doc.title %>
                                                                    </span>
                                                                    <a href="<%= doc.url %>" target="_blank"
                                                                        class="text-[10px] text-blue-500 dark:text-blue-400 px-2 py-0.5 bg-white dark:bg-slate-900 rounded border border-slate-200 dark:border-slate-700">View</a>
                                                                </div>
                                                                <% }) %>
                                                        </div>

                                                        <button onclick="toggleAccordion('<%= empIndex %>')"
                                                            id="arrow-btn-<%= empIndex %>"
                                                            class="text-[11px] text-slate-400 dark:text-slate-500 hover:text-blue-500 font-medium flex items-center gap-1 mt-1 transition-colors">
                                                            Show More (<%= emp.documents.length - 1 %>)
                                                                <span id="arrow-svg-<%= empIndex %>"
                                                                    class="inline-block transition-transform duration-200">▼</span>
                                                        </button>
                                                        <% } %>
                                                            <% } else { %>
                                                                <span class="text-xs text-slate-400">No files
                                                                    uploaded</span>
                                                                <% } %>
                                            </div>
                                        </td>

                                        <td class="p-4 text-center">
                                            <div class="flex items-center justify-center gap-2">
                                                <button
                                                    onclick="openEditModal('<%= emp._id %>', '<%= emp.name %>', '<%= emp.position %>', '<%= JSON.stringify(emp.documents) %>')"
                                                    class="text-xs text-amber-600 hover:text-white font-bold px-2.5 py-1.5 bg-white dark:bg-slate-900 hover:bg-amber-500 border border-amber-200 dark:border-amber-800 rounded-lg shadow-sm transition-all">
                                                    Edit
                                                </button>
                                                <form action="/delete/<%= emp._id %>" method="POST"
                                                    onsubmit="return confirm('Delete record?');">
                                                    <button type="submit"
                                                        class="text-xs text-rose-600 hover:text-white font-bold px-2.5 py-1.5 bg-white dark:bg-slate-900 hover:bg-rose-600 border border-rose-200 dark:border-rose-800 rounded-lg shadow-sm transition-all">Wipe</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                                            <tr id="search-empty-row" class="hidden">
                                                <td colspan="4" class="p-12 text-center text-slate-400">No records
                                                    found.</td>
                                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="edit-modal"
        class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <div
            class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 w-full max-w-lg p-6 shadow-2xl m-4 transform scale-95 transition-transform duration-300">
            <div class="flex justify-between items-center border-b border-slate-100 dark:border-slate-800 pb-3 mb-4">
                <h3 class="text-base font-bold text-slate-800 dark:text-slate-100">Modify Vault Record</h3>
                <button type="button" onclick="closeEditModal()"
                    class="text-slate-400 hover:text-slate-600 font-bold">✕</button>
            </div>

            <form id="edit-form" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Full Name</label>
                    <input type="text" id="edit-name" name="name" required
                        class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 rounded-xl dark:bg-slate-800 text-sm">
                </div>
                <div>
                    <label
                        class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Designation</label>
                    <input type="text" id="edit-position" name="position" required
                        class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 rounded-xl dark:bg-slate-800 text-sm">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5">Currently
                        Stored Documents (Click ✕ to remove)</label>
                    <div id="existing-docs-list"
                        class="space-y-2 max-h-[140px] overflow-y-auto border border-slate-100 dark:border-slate-800 p-2 rounded-xl bg-slate-50/50 dark:bg-slate-800/30">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Upload Additional
                        / New Files</label>
                    <div
                        class="bg-slate-50 dark:bg-slate-800 p-4 rounded-xl border border-dashed border-slate-300 dark:border-slate-700 text-center hover:bg-slate-100/50 dark:hover:bg-slate-800/80 transition-all relative mb-3">
                        <input type="file" name="documents" id="edit-master-file-input" multiple
                            onchange="handleBulkFilesSelection(this, 'edit-bulk-names-container')"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                        <div class="text-slate-400 dark:text-slate-500 space-y-1">
                            <p class="text-xs font-bold text-amber-500 dark:text-amber-400">Click to Select New Files
                            </p>
                            <p class="text-[10px]">Multiple documents can be chosen together</p>
                        </div>
                    </div>
                    <div id="edit-bulk-names-container" class="space-y-2 max-h-[180px] overflow-y-auto pr-1"></div>
                </div>

                <div class="flex justify-end gap-3 border-t border-slate-100 dark:border-slate-800 pt-4 mt-6">
                    <button type="button" onclick="closeEditModal()"
                        class="px-4 py-2 border border-slate-200 dark:border-slate-700 text-xs font-bold rounded-xl text-slate-600 dark:text-slate-400">Cancel</button>
                    <button type="submit"
                        class="px-5 py-2 bg-slate-900 dark:bg-blue-600 text-white text-xs font-bold rounded-xl shadow-md">Apply
                        Updates</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const htmlTag = document.getElementById('html-tag');
        const sunIcon = document.getElementById('sun-icon');
        const moonIcon = document.getElementById('moon-icon');

        if (localStorage.getItem('theme') === 'dark') {
            htmlTag.classList.add('dark'); sunIcon.classList.remove('hidden'); moonIcon.classList.add('hidden');
        }

        function toggleTheme() {
            if (htmlTag.classList.contains('dark')) {
                htmlTag.classList.remove('dark'); localStorage.setItem('theme', 'light');
                sunIcon.classList.add('hidden'); moonIcon.classList.remove('hidden');
            } else {
                htmlTag.classList.add('dark'); localStorage.setItem('theme', 'dark');
                sunIcon.classList.remove('hidden'); moonIcon.classList.add('hidden');
            }
        }

        // 🛠️ MULTIPLE BROWSER SELECTION CONTROLLER FUNCTION
        function handleBulkFilesSelection(inputElement, containerId) {
            const container = document.getElementById(containerId);
            container.innerHTML = '';

            const files = inputElement.files;
            if (files.length === 0) return;

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const card = document.createElement('div');
                card.className = 'bg-slate-50 dark:bg-slate-800 p-3 rounded-xl border border-slate-200/80 dark:border-slate-700/60 space-y-1.5 shadow-sm';
                card.innerHTML = `
                    <div class="flex justify-between items-center text-[11px] font-bold text-slate-400 dark:text-slate-500">
                        <span class="truncate max-w-[75%]">📄 ${file.name}</span>
                        <span>(${(file.size / 1024).toFixed(1)} KB)</span>
                    </div>
                    <input type="text" name="docNames" placeholder="Label name (e.g. Aadhaar Card)" required 
                           class="w-full px-3 py-1.5 border border-slate-200 dark:border-slate-600 rounded-lg text-xs bg-white dark:bg-slate-700 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
                `;
                container.appendChild(card);
            }
        }

        function toggleAccordion(index) {
            const container = document.getElementById(`extra-docs-${index}`);
            const btn = document.getElementById(`arrow-btn-${index}`);
            const arrow = document.getElementById(`arrow-svg-${index}`);
            const totalExtra = container.children.length;

            if (container.classList.contains('hidden')) {
                container.classList.remove('hidden');
                arrow.style.transform = "rotate(180deg)";
                btn.firstChild.textContent = "Hide Extra ";
            } else {
                container.classList.add('hidden');
                arrow.style.transform = "rotate(0deg)";
                btn.firstChild.textContent = `Show More (${totalExtra}) `;
            }
        }

        function filterRecords() {
            const query = document.getElementById('search-input').value.toLowerCase().trim();
            const rows = document.querySelectorAll('.record-row');
            const emptyRow = document.getElementById('search-empty-row');
            const counter = document.getElementById('active-counter');
            let visibleCount = 0;

            rows.forEach(row => {
                const name = row.querySelector('.search-name').textContent.toLowerCase();
                const pos = row.querySelector('.search-position').textContent.toLowerCase();
                if (name.includes(query) || pos.includes(query)) {
                    row.classList.remove('hidden'); visibleCount++;
                } else { row.classList.add('hidden'); }
            });
            counter.textContent = `Active Logs: ${visibleCount}`;
            if (visibleCount === 0 && rows.length > 0) emptyRow.classList.remove('hidden'); else emptyRow.classList.add('hidden');
        }

        function openEditModal(id, name, position, documentsJson) {
            const modal = document.getElementById('edit-modal');
            const form = document.getElementById('edit-form');
            const existingContainer = document.getElementById('existing-docs-list');

            document.getElementById('edit-name').value = name;
            document.getElementById('edit-position').value = position;
            document.getElementById('edit-bulk-names-container').innerHTML = '';
            document.getElementById('edit-master-file-input').value = '';
            existingContainer.innerHTML = '';

            form.action = `/update/${id}`;
            const docs = JSON.parse(documentsJson);

            if (docs && docs.length > 0) {
                docs.forEach(doc => {
                    const docRow = document.createElement('div');
                    docRow.className = 'flex items-center justify-between bg-white dark:bg-slate-800 px-3 py-1.5 rounded-xl border border-slate-200/60 dark:border-slate-700 text-xs shadow-sm';
                    docRow.innerHTML = `
                        <span class="font-bold text-slate-700 dark:text-slate-300 truncate mr-2">${doc.title}</span>
                        <input type="hidden" name="retainedDocs" value="${doc._id}">
                        <button type="button" onclick="this.parentElement.remove()" class="text-rose-500 hover:text-rose-700 font-extrabold px-1">✕</button>
                    `;
                    existingContainer.appendChild(docRow);
                });
            } else {
                existingContainer.innerHTML = `<p class="text-slate-400 text-xs text-center py-2">No documents currently assigned.</p>`;
            }

            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.querySelector('.transform').classList.remove('scale-95');
            }, 10);
        }

        function closeEditModal() {
            const modal = document.getElementById('edit-modal');
            modal.classList.add('opacity-0');
            modal.querySelector('.transform').classList.add('scale-95');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }
    </script>
</body>

</html>